{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/logbook-prime.sh\"",
            "timeout": 10,
            "statusMessage": "Priming from DECISIONS.md + CHANGELOG"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/logbook-nudge.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
